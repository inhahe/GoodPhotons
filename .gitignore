# Build output
/build/
/build_cuda/
/build_cuda2/
/build_het/
/build_verify/
/out/
# ftrace.exe copied into the repo root by build.bat (build artifact)
/ftrace.exe
*.ppm
*.exr
*.png
*.jpg
*.jpeg
*.gif
*.mp4
*.webp

# 3D model assets (large binaries kept on disk, never committed — cameras/, meshes/,
# Meshy_* textures, etc. Scenes reference them locally; they don't belong in history.)
*.glb
*.gltf
*.usdz
*.usda
*.zip

# Render state / checkpoints / photon maps (crash-safe sidecars, regenerated on render)
*.ftbuf
*.ftpmap

# Render logs
*.log

# Cached web reference dumps (POV-Wiki pages saved with "... - POV-Wiki_files/" dirs)
*POV-Wiki.html
*POV-Wiki_files/

# Generated meshes (regenerate with tools/make_mesh.py)
*.obj

# Reference PDFs (e.g. Kodak Wratten handbook used to digitize filter data)
*.pdf

# Checkpoints / render state
*.ckpt
/renders/

# Scratch / throwaway scripts and test outputs
/scraps/

# Raw upstream data dumps (kept locally; derived + attributed CSVs live in data/)
/data_raw/

# Cached POV-Ray source fetched by tools/pov_*_gen.py (AGPL; re-fetched on demand)
/tools/.pov_fnintern.cpp
/tools/.pov_noise.cpp
/tools/.pov_portablenoise.cpp

# Python bytecode cache
__pycache__/
*.pyc

# Editor / IDE
.vs/
.vscode/
*.user

# Agent runtime
.claude/

# OS
Thumbs.db
Desktop.ini
/build_nocuda/
