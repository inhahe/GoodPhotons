# Phase C test: analytic sphere under NON-UNIFORM scale + SHEAR now auto-tessellates
# into a smooth-normal ellipsoid / sheared quadric instead of failing to load.
scene { units meters  spectral 360 830 1 }
material "white" { type diffuse reflect whitewall 0.75 }
material "red"   { type diffuse reflect redwall }

quad { origin 0 0 0   u 1 0 0   v 0 0 1   material white }   # floor

# Ellipsoid: unit sphere squashed to radii (0.25, 0.12, 0.25) — a flattened disc.
group { translate 0.3 0.12 0.5   scale 0.25 0.12 0.25   sphere { center 0 0 0  radius 1  material red } }

# Sheared sphere: uniform 0.18 then shear x += 0.9*y (leans over as it rises).
group { translate 0.72 0.18 0.5   scale 0.18 0.18 0.18   shear 0.9 0 0   sphere { center 0 0 0  radius 1  material red } }

light area { origin 0.35 0.999 0.35  u 0.30 0 0  v 0 0 0.30  normal 0 -1 0  spd preset:bb6500 }
camera "cam" { eye 0.5 0.5 2.7  look_at 0.5 0.25 0.5  up 0 1 0  fov_y 45  mode B  film { res 160 160 } }
